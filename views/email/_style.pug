style.
  /* ── Reset ── */
  img { border:none; -ms-interpolation-mode:bicubic; max-width:100%; display:block; }
  body {
    background-color:#F6F1E5;
    font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;
    -webkit-font-smoothing:antialiased;
    font-size:15px;
    line-height:1.6;
    margin:0; padding:0;
    -ms-text-size-adjust:100%;
    -webkit-text-size-adjust:100%;
    color:#1F2D24;
  }
  table { border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt; width:100%; }
  table td { font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:15px; vertical-align:top; }

  /* ── Outer wrapper ── */
  .body { background-color:#F6F1E5; width:100%; }
  .container {
    display:block;
    margin:0 auto !important;
    max-width:560px;
    padding:24px 16px;
    width:560px;
  }
  .content { box-sizing:border-box; display:block; margin:0 auto; max-width:560px; }

  /* ── Card ── */
  .main {
    background:#FCFAF4;
    border-radius:6px;
    border:1px solid #D9D0BC;
    width:100%;
    overflow:hidden;
  }

  /* ── Header band ── */
  .header-band {
    background-color:#2B3F32;
    padding:28px 32px;
    text-align:center;
  }
  .header-band .logo-text {
    font-size:26px;
    font-weight:700;
    color:#FCFAF4;
    letter-spacing:1px;
    text-decoration:none;
  }
  .header-band .logo-dot { color:#BD5630; }

  /* ── Body ── */
  .wrapper { box-sizing:border-box; padding:36px 40px; }

  h1 {
    color:#2B3F32;
    font-size:26px;
    font-weight:700;
    line-height:1.3;
    margin:0 0 16px 0;
  }
  p { color:#1F2D24; font-size:15px; line-height:1.7; margin:0 0 18px 0; }
  p.muted { color:#6B7C72; font-size:13px; }

  /* ── Divider ── */
  .divider {
    border:none;
    border-top:1px dashed #D9D0BC;
    margin:28px 0;
  }

  /* ── Button ── */
  .btn-wrap { text-align:center; margin:32px 0; }
  .btn {
    display:inline-block;
    background-color:#2B3F32;
    color:#FCFAF4 !important;
    font-size:15px;
    font-weight:600;
    text-decoration:none;
    padding:14px 36px;
    border-radius:6px;
    letter-spacing:0.3px;
  }
  .btn:hover { background-color:#1F2D24; }

  /* ── Token box (for OTP codes) ── */
  .token-box {
    background:#F6F1E5;
    border:1px dashed #D9D0BC;
    border-radius:6px;
    padding:20px;
    text-align:center;
    margin:24px 0;
  }
  .token-code {
    font-family:'Courier New', Courier, monospace;
    font-size:36px;
    font-weight:700;
    letter-spacing:10px;
    color:#2B3F32;
  }
  .token-expiry { font-size:12px; color:#6B7C72; margin-top:8px; }

  /* ── Paw icon ── */
  .paw { font-size:28px; margin-bottom:8px; }

  /* ── Footer ── */
  .footer { clear:both; margin-top:24px; text-align:center; padding:0 16px 24px; }
  .footer p { color:#6B7C72; font-size:12px; margin:4px 0; }
  .footer a { color:#6B7C72; text-decoration:underline; }

  /* ── Warning box ── */
  .warning {
    background:#FFF8F5;
    border-left:3px solid #BD5630;
    border-radius:0 4px 4px 0;
    padding:14px 18px;
    margin:20px 0;
  }
  .warning p { color:#BD5630; font-size:13px; margin:0; }
