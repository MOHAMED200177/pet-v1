extends baseEmail

block content
  //- Greeting
  h1 Reset your password
  p
    | Hi #{firstName},
  p
    | We received a request to reset the password for your Petopia account.
    | Click the button below to choose a new password.
    | This link is valid for&nbsp;
    strong 10 minutes only.

  //- CTA Button
  .btn-wrap
    a.btn(href=url, target='_blank') Reset my password

  hr.divider

  //- Security note
  .warning
    p
      | ⚠️&nbsp;
      strong Didn't request this?
      |  No action is needed — your password will remain unchanged.
      | If you're concerned about your account security, please contact us.

  hr.divider

  //- Fallback link
  p.muted
    | If the button above doesn't work, copy and paste this link into your browser:
  p.muted
    a(href=url, style='color:#2B3F32; word-break:break-all;')= url
