<file path="views/email/passwordReset.pug">
extends baseEmail

block content
  table.main-container(role='presentation', width='100%', border='0', cellpadding='0', cellspacing='0', style='background-color: #b1dcff; font-family: Arial, sans-serif; padding: 30px; text-align: center; border-radius: 20%; box-shadow: 14px 14px 10px rgba(0, 0, 0, 0.5);')
    tbody
      tr
        td(style='padding: 20px;')
          h1(style='color: #ffffff00; font-size: 24px; margin-bottom: 36px; text-shadow: 1px 20px 3px #023d0f;') Password Reset Request
          p(style='color: #000000; font-size: 16px; line-height: 2;')
            | Hi #{firstName},<br>
            | Forgot your password? No worries! Just click the button below to reset it.
          table.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0', style='margin: 20px auto;')
            tbody
              tr
                td(style='padding: 0;')
                  a(href=`${url}`, target='_blank', style='background-color: #1ef3e7; color: #fff; padding: 16px 20px; font-size: 16px; text-decoration: none; border-radius: 10%;box-shadow: -4px 3px 20px 2px rgb(253 253 253 / 50%)') Reset your password
          p(style='color: red; font-size: 14px; margin-top: 40px; line-height: 1.6;')
            | If you didn't request a password reset, no action is needed.<br>
            | Please ignore this email.

      tr
        td(style='padding: 10px 0;')
          hr(style='border: none; border-top: 1px solid #ddd; margin: 20px auto; width: 80%;')
          p(style='color: #888; font-size: 12px;')
            | &copy; 2024 potapia. All rights reserved.
</file>

